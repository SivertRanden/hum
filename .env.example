# ── Hum App — Environment Variables ──────────────────────────────────────────
# Copy this file to .env and fill in the values before running.
#
#   cp .env.example .env

# ── Backend ───────────────────────────────────────────────────────────────────

# Secret used to sign JWT tokens. Must be long and random in production.
# Generate one with: openssl rand -hex 32
JWT_SECRET=change-me-in-production

# Port the backend HTTP/WS server listens on inside the container (default 3001)
# PORT=3001

# Path to the SQLite database file inside the container
# DB_PATH=/data/hum.db

# Allowed CORS origin for the frontend. Used for /invite/ redirects too.
# In production set this to the public URL where the frontend is served.
CLIENT_ORIGIN=http://localhost

# ── Email (Resend) ────────────────────────────────────────────────────────────

# API key for the Resend email provider. Leave unset in dev to log emails to console.
# RESEND_API_KEY=re_...

# Sender address used for all outgoing emails.
# EMAIL_FROM=noreply@hum.app

# ── Development / Testing ─────────────────────────────────────────────────────

# Set to any non-empty value to disable HTTP rate limiting (e2e / local dev only).
# NEVER set this in production.
# DISABLE_RATE_LIMIT=true

# ── Frontend / Compose ────────────────────────────────────────────────────────

# Host port the frontend nginx container binds to (default 80)
# PORT=80
