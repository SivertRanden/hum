{
  "name": "hum",
  "private": true,
  "version": "0.1.0",
  "description": "Voice-first communication — stripped back to what matters.",
  "packageManager": "pnpm@8.5.1",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"pnpm --filter @hum/server dev\" \"pnpm --filter @hum/client dev\"",
    "build": "pnpm --filter @hum/server build && pnpm --filter @hum/client build",
    "lint": "eslint packages/*/src --ext .ts,.tsx"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "typescript": "^5.4.5"
  }
}
